# ---- App ----
APP_NAME=OneFlowAI Platform
APP_ENV=development
DEBUG=false
API_V1_PREFIX=/api/v1

# ---- Logging ----
LOG_LEVEL=INFO
LOG_JSON=true

# ---- PostgreSQL ----
# When running via docker-compose, POSTGRES_HOST is overridden to "postgres".
# For running the app locally against compose services, use "localhost".
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=oneflowai
POSTGRES_PASSWORD=oneflowai
POSTGRES_DB=oneflowai
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ---- Qdrant ----
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ---- JWT ----
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
